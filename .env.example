# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# --- PostgreSQL ---
# Local connection defaults. Change DB_NAME/DB_USER/DB_PASSWORD to match your setup.
# Run once as superuser to create the DB and enable pgvector:
#   createdb rag_db
#   psql -d rag_db -c 'CREATE EXTENSION IF NOT EXISTS vector;'
DB_HOST=localhost
DB_NAME=rag_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# --- Dropbox ---
# Create an app at https://www.dropbox.com/developers/apps
# Under "Permissions", enable: files.content.read
# Under "Settings", generate an access token and paste it here.
DROPBOX_ACCESS_TOKEN=your_dropbox_access_token

# --- Google Drive ---
# Credentials are handled via OAuth, not an env var.
# Download credentials.json from https://console.cloud.google.com/
#   1. Create a project → Enable the Drive API
#   2. Create OAuth 2.0 credentials (Desktop app)
#   3. Download and place as data/drive/credentials.json
# On first run, download_drive_files.py will open a browser for authorization
# and cache the token at data/drive/token.json (also gitignored).
